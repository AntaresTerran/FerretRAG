server:
  host: 127.0.0.1
  port: 8765
  open_browser: true

model:
  # Gemma 4 needs a newer llama.cpp build than the pinned CPU wheel currently provides.
  # Use Qwen for stronger local answers, or Llama 3.2 1B for faster smoke tests.
  path: models/Qwen3.5-9B-UD-IQ3_XXS.gguf
  n_ctx: 4096
  gpu_layers: auto

index:
  data_dir: data
  chunk_words: 300
  chunk_overlap: 50
  top_k: 5
